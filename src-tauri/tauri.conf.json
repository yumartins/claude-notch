{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-notch",
  "version": "0.1.0",
  "identifier": "com.yuri.claudenotch",
  "build": {
    "beforeDevCommand": "bun run vite:dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "claude-notch",
        "width": 406,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
